# =============================================================
# batty - AI Idea Pipeline Configuration
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   chmod 600 .env
# =============================================================

# Your Telegram bot token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your nicodAImus API key (get from nicodaimus.com/account/manage)
NICODAIMUS_API_KEY=your_api_key_here

# Your Telegram chat ID - the daily review script sends digests here
# To find your chat ID: send any message to @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_chat_id_here

# Your project name (used in bot messages and AI prompts)
PROJECT_NAME=My Ideas Pipeline

# Path to your TODO markdown file (optional - enables duplicate detection against backlog)
# TODO_FILE=./docs/TODO.md

# Path to your STATUS markdown file (optional - enables duplicate detection against shipped features)
# STATUS_FILE=./docs/STATUS.md

# Where to save review report files (default: ./reports)
# REPORTS_DIR=./reports

# =============================================================
# Advanced settings - leave as-is unless you know what you're doing
# =============================================================

# Internal URL for the ideas store (used by n8n and the review script)
IDEAS_STORE_URL=http://ideas-store:9321

# Port exposed by the ideas store container
PORT=9321

# Data directory inside the ideas-store container
DATA_DIR=/app/data
