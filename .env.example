# =============================================================
# batty - AI Idea Pipeline Configuration
# =============================================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#   chmod 600 .env
# =============================================================

# Your Telegram bot token (get from @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your nicodAImus API key (get from nicodaimus.com/account/manage)
NICODAIMUS_API_KEY=your_api_key_here

# Your Telegram chat ID - the daily review script sends digests here
# To find your chat ID: send any message to @userinfobot on Telegram
TELEGRAM_CHAT_ID=your_chat_id_here

# Your project name (used in bot messages and AI prompts)
PROJECT_NAME=My Ideas Pipeline

# Path to your TODO markdown file (optional - enables duplicate detection against backlog)
# TODO_FILE=./docs/TODO.md

# Path to your STATUS markdown file (optional - enables duplicate detection against shipped features)
# STATUS_FILE=./docs/STATUS.md

# Where to save review report files (default: ./reports)
# REPORTS_DIR=./reports

# =============================================================
# Multi-project mode (optional)
# =============================================================
# Batty can route ideas into multiple projects from a single Telegram bot.
# To enable, set PROJECTS to a comma-separated list. The first entry is the
# default when project cannot be determined from the message.
#
# When enabled:
#  - Every idea is tagged with a project in the bot output: [web] #12 ...
#  - /list, /status, /archive accept a project filter: /list mobile
#  - The AI detects which project each idea belongs to from [prefix] or
#    name mention in the message. Ambiguous input falls back to the first project.
#  - Daily and weekly reports group ideas by project
#
# PROJECTS=web,mobile,ops
#
# Optional: per-project TODO and STATUS files for duplicate detection
# (env var pattern: PROJECT_<NAME>_TODO / PROJECT_<NAME>_STATUS)
# PROJECT_web_TODO=./web/TODO.md
# PROJECT_mobile_TODO=./mobile/TODO.md
# PROJECT_ops_TODO=./ops/TODO.md

# =============================================================
# Advanced settings - leave as-is unless you know what you're doing
# =============================================================

# Internal URL for the ideas store (used by n8n and the review script)
IDEAS_STORE_URL=http://ideas-store:9321

# Port exposed by the ideas store container
PORT=9321

# Data directory inside the ideas-store container
DATA_DIR=/app/data
